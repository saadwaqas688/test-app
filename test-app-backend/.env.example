# Supabase project
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Server-side SECRET key (sb_secret_...). Set this in your host's env, never commit it.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Shared token the desktop app uses to push data (make up a long random string)
INGEST_TOKEN=change-me-to-a-long-random-string

# Admin dashboard login
ADMIN_USER=admin
ADMIN_PASS=change-me

# Port (Render/Railway set this automatically)
PORT=3000
